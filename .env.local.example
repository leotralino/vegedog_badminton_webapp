# Copy this file to .env.local and fill in your values
# Get these from https://supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: set to your deployed domain for OAuth redirects
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Email (for 发给球馆 + follower notifications)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Gmail → Security → App Passwords
# COURT_EMAIL=court@example.com            # comma-separated for multiple recipients

# Supabase service role key (for reading auth.users emails in follower notifications)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Supabase → Settings → API → service_role

# E2E tests (Playwright) — create a dedicated test account on your dev DB
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=your-test-password
